# Host/IP that Docker publishes on. Keep 127.0.0.1 for local-only use.
SS_BIND_HOST=127.0.0.1

# Hostname/IP printed in the ss:// connection URL in container logs.
# For LAN use, set this to the Docker host's LAN IP.
SS_URL_HOST=127.0.0.1
SS_URL_NAME=cf-warp-shadowsocks

# SOCKS5 client settings. Auth is disabled when username/password are empty.
SOCKS_BIND_HOST=127.0.0.1
SOCKS_PORT=1080
SOCKS_URL_HOST=127.0.0.1
SOCKS_USERNAME=
SOCKS_PASSWORD=

# Host user/group ownership for generated ./warp files.
PUID=1000
PGID=1000

# Shadowsocks client settings.
SS_PORT=8388
SS_METHOD=chacha20-ietf-poly1305
SS_PASSWORD=replace-with-a-long-random-password

# Runtime logging.
LOG_LEVEL=info

# Cloudflare WARP's usual MTU.
WARP_MTU=1280
